---
import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";

import { Agentify } from "@/components/sections/agentify";
import { Cloud } from "@/components/sections/cloud";
import { Features } from "@/components/sections/features";
import { Hero } from "@/components/sections/hero";
import { Surfaces } from "@/components/sections/surfaces";
import { TrustedTeams } from "@/components/sections/trusted-teams";
import DefaultLayout from "@/layouts/DefaultLayout.astro";
---

<DefaultLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
  <Hero client:load />
  <TrustedTeams />
  <Features client:visible />
  <Surfaces />
  <Cloud />
  <Agentify />
</DefaultLayout>
